{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 02 - GraphRAG Eval for Thesis\\n",
    "Đọc `results/final_metrics.json` và xuất bảng để điền vào LaTeX."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\\n",
    "import json, pandas as pd\\n",
    "\\n",
    "fp = Path('results/final_metrics.json')\\n",
    "data = json.loads(fp.read_text(encoding='utf-8'))\\n",
    "\\n",
    "rows=[]\\n",
    "for model_key, model_name in [('naive_rag','Naive/PaddedRAG'), ('graphrag','GraphRAG')]:\\n",
    "    m = data[model_key]['overall']\\n",
    "    rows.append({\\n",
    "        'model': model_name,\\n",
    "        'MRR': m.get('mrr'),\\n",
    "        'NDCG@5': m.get('ndcg_at_5'),\\n",
    "        'Faithfulness': m.get('faithfulness'),\\n",
    "        'Latency P50 (ms)': m.get('latency_median_ms'),\\n",
    "        'Latency P95 (ms)': m.get('latency_p95_ms')\\n",
    "    })\\n",
    "\\n",
    "df = pd.DataFrame(rows)\\n",
    "df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "latex_rows = []\\n",
    "for _, r in df.iterrows():\\n",
    "    latex_rows.append(f\"{r['model']} & {r['MRR']} & {r['NDCG@5']} & {r['Faithfulness']} & {r['Latency P50 (ms)']} \\\\\\")\\n",
    "print('\\n'.join(latex_rows))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "out = Path('results/thesis_eval_summary.csv')\\n",
    "df.to_csv(out, index=False, encoding='utf-8-sig')\\n",
    "print('Saved:', out.resolve())"
   ]
  }
 ],
