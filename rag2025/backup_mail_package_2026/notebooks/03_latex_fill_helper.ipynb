   "source": [
    "# 03 - LaTeX Fill Helper\\n",
    "Tạo snippet hàng bảng để paste nhanh vào `rag-2026.tex` và `rag-chunking-2026.tex`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\\n",
    "import json\\n",
    "\\n",
    "metrics = json.loads(Path('results/final_metrics.json').read_text(encoding='utf-8'))\\n",
    "n = metrics['metadata']['n_questions']\\n",
    "print('n_questions =', n)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "naive = metrics['naive_rag']['overall']\\n",
    "graph = metrics['graphrag']['overall']\\n",
    "\\n",
    "print('% Paste to rag-chunking-2026 table (custom row):')\\n",
    "print(f\"Naive/PaddedRAG & {naive['mrr']} & {naive['ndcg_at_5']} & {naive['faithfulness']} & -- \\\\\\")\\n",
    "print(f\"GraphRAG & {graph['mrr']} & {graph['ndcg_at_5']} & {graph['faithfulness']} & -- \\\\\\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "imp = metrics.get('improvement_over_baseline', {})\\n",
    "print('Improvement summary for text section:')\\n",
    "for k, v in imp.get('overall', {}).items():\\n",
    "    print('-', k, ':', v)"
   ]
  }
