{"id": "thi_sinh_khoahoc_qd_310_tran_tang_hoc_phi_20_2024", "doc_id": "chunked_9", "chunk_id": 0, "text": "### thi sinh khoahoc qd 310 tran tang hoc phi 20 2024\n\nTheo Quyết định 310/QĐ-ĐHH (29/03/2024), lộ trình tăng học phí (nếu có) của Trường Đại học Khoa học – Đại học Huế mỗi năm không vượt quá 20% so với mức của năm liền kề.", "text_plain": "Tran tang hoc phi toi da 20% moi nam theo QD 310/QD-DHH.", "summary": "Trần tăng học phí tối đa 20%/năm theo QĐ 310/QĐ-ĐHH.", "metadata": {"source": "Quyết định 310/QĐ-ĐHH ngày 29/03/2024 (Đại học Huế)", "effective_date": "2024-03-29", "info_type": "hoc_phi_va_chi_phi", "audience": "thi_sinh", "issuer": "Dai_Hoc_Hue", "unit": "Khoa_Hoc", "year": "2024", "admission_cycle": 2025, "expired": false, "citations": ["Trần tăng học phí ≤20%/năm (QĐ 310/QĐ-ĐHH)"], "docno": "310/QĐ-ĐHH", "percent_cap_max": 20, "source_type": "jsonl", "faq_type": "hoc_phi_va_chi_phi"}, "breadcrumbs": ["Quyết định 310/QĐ-ĐHH ngày 29/03/2024 (Đại học Huế)"], "prev_chunk_id": "", "next_chunk_id": "thi_sinh_khoahoc_qd_310_tie_breaker_gpa12_2024", "sparse_terms": ["quyết", "định", "310", "đhh", "2024", "trình", "tăng", "học", "phí", "nếu", "trường", "đại", "học", "khoa", "học", "đại", "học", "huế", "mỗi", "năm", "vượt", "quá", "mức", "năm", "liền"]}
{"id": "thi_sinh_khoahoc_qd_310_tie_breaker_gpa12_2024", "doc_id": "chunked_9", "chunk_id": 2, "text": "### thi sinh khoahoc qd 310 tie breaker gpa12 2024\n\nHọc bổng Thủ khoa/Á khoa của Trường Đại học Khoa học – Đại học Huế dựa trên điểm thi tốt nghiệp THPT năm 2024 (không tính điểm ưu tiên/điểm cộng). Trường hợp bằng điểm, tiêu chí phụ là kết quả học tập trung bình cả năm lớp 12.", "text_plain": "Neu dong diem, xet GPA ca nam lop 12 lam tieu chi phu cho hoc bong Thu khoa/A khoa.", "summary": "Nếu đồng điểm khi xét học bổng Thủ khoa/Á khoa, dùng GPA cả năm lớp 12 làm tiêu chí phụ.", "metadata": {"source": "Quyết định 310/QĐ-ĐHH ngày 29/03/2024 (Đại học Huế)", "effective_date": "2024-03-29", "info_type": "uu_tien_xet_tuyen", "info_subtype": "hoc_bong", "audience": "thi_sinh", "issuer": "Dai_Hoc_Hue", "unit": "Khoa_Hoc", "year": "2024", "admission_cycle": 2025, "expired": false, "citations": ["Tie-breaker: GPA lớp 12 (QĐ 310/QĐ-ĐHH)"], "docno": "310/QĐ-ĐHH", "tie_breaker": "gpa12", "source_type": "jsonl", "faq_type": "tieu_chi_phu"}, "breadcrumbs": ["Quyết định 310/QĐ-ĐHH ngày 29/03/2024 (Đại học Huế)"], "prev_chunk_id": "thi_sinh_khoahoc_qd_310_tran_tang_hoc_phi_20_2024", "next_chunk_id": "thi_sinh_khoahoc_qd_310_hoc_bong_28_plus_2024", "sparse_terms": ["học", "bổng", "thủ", "khoa", "khoa", "trường", "đại", "học", "khoa", "học", "đại", "học", "huế", "dựa", "trên", "điểm", "thi", "tốt", "nghiệp", "thpt", "năm", "2024", "tính", "điểm", "tiên", "điểm", "cộng", "trường", "hợp", "điểm", "tiêu", "chí", "phụ", "kết", "quả", "học", "tập", "trung", "bình", "năm", "lớp"]}
{"id": "thi_sinh_khoahoc_qd_310_hoc_bong_28_plus_2024", "doc_id": "chunked_9", "chunk_id": 4, "text": "### thi sinh khoahoc qd 310 hoc bong 28 plus 2024\n\nThí sinh có điểm thi tốt nghiệp THPT năm 2024 từ 28,00 trở lên (không tính điểm ưu tiên/điểm cộng) được cấp học bổng tương đương học phí của năm học thứ tư tại Trường Đại học Khoa học – Đại học Huế.", "text_plain": "Diem thi THPT >= 28.00 duoc hoc bong = hoc phi ca nam 4.", "summary": "Điểm thi THPT ≥ 28,00 → học bổng bằng học phí cả năm 4 (không tính ưu tiên/điểm cộng).", "metadata": {"source": "Quyết định 310/QĐ-ĐHH ngày 29/03/2024 (Đại học Huế)", "effective_date": "2024-03-29", "info_type": "uu_tien_xet_tuyen", "info_subtype": "hoc_bong", "audience": "thi_sinh", "issuer": "Dai_Hoc_Hue", "unit": "Khoa_Hoc", "year": "2024", "admission_cycle": 2025, "expired": false, "citations": ["Mốc ≥28,00: học phí năm 4 (QĐ 310/QĐ-ĐHH)"], "docno": "310/QĐ-ĐHH", "score_scale": "THPT/30", "score_min": 28.0, "benefit": "tuition_year4", "source_type": "jsonl", "faq_type": "quyen_loi_thi_sinh"}, "breadcrumbs": ["Quyết định 310/QĐ-ĐHH ngày 29/03/2024 (Đại học Huế)"], "prev_chunk_id": "thi_sinh_khoahoc_qd_310_tie_breaker_gpa12_2024", "next_chunk_id": "thi_sinh_khoahoc_qd_310_hoc_bong_26_28_2024", "sparse_terms": ["thí", "sinh", "điểm", "thi", "tốt", "nghiệp", "thpt", "năm", "2024", "trở", "lên", "tính", "điểm", "tiên", "điểm", "cộng", "cấp", "học", "bổng", "tương", "đương", "học", "phí", "năm", "học", "thứ", "tại", "trường", "đại", "học", "khoa", "học", "đại", "học", "huế"]}
{"id": "thi_sinh_khoahoc_qd_310_hoc_bong_26_28_2024", "doc_id": "chunked_9", "chunk_id": 6, "text": "### thi sinh khoahoc qd 310 hoc bong 26 28 2024\n\nThí sinh có điểm thi tốt nghiệp THPT năm 2024 từ 26,00 đến dưới 28,00 (không tính điểm ưu tiên/điểm cộng) được cấp học bổng tương đương học phí học kỳ I của năm học thứ tư tại Trường Đại học Khoa học – Đại học Huế.", "text_plain": "Diem thi THPT 26.00-den-duoi-28.00 duoc hoc bong = hoc phi HK1 nam 4.", "summary": "Điểm thi THPT 26,00–<28,00 → học bổng bằng học phí HK1 năm 4 (không tính ưu tiên/điểm cộng).", "metadata": {"source": "Quyết định 310/QĐ-ĐHH ngày 29/03/2024 (Đại học Huế)", "effective_date": "2024-03-29", "info_type": "uu_tien_xet_tuyen", "info_subtype": "hoc_bong", "audience": "thi_sinh", "issuer": "Dai_Hoc_Hue", "unit": "Khoa_Hoc", "year": "2024", "admission_cycle": 2025, "expired": false, "citations": ["Mốc 26,00–<28,00: học phí HK1 năm 4 (QĐ 310/QĐ-ĐHH)"], "docno": "310/QĐ-ĐHH", "score_scale": "THPT/30", "score_min": 26.0, "score_max": 27.99, "benefit": "tuition_sem1_year4", "source_type": "jsonl", "faq_type": "quyen_loi_thi_sinh"}, "breadcrumbs": ["Quyết định 310/QĐ-ĐHH ngày 29/03/2024 (Đại học Huế)"], "prev_chunk_id": "thi_sinh_khoahoc_qd_310_hoc_bong_28_plus_2024", "next_chunk_id": "thi_sinh_khoahoc_qd_310_hoc_bong_khong_tinh_uu_tien_2024", "sparse_terms": ["thí", "sinh", "điểm", "thi", "tốt", "nghiệp", "thpt", "năm", "2024", "đến", "dưới", "tính", "điểm", "tiên", "điểm", "cộng", "cấp", "học", "bổng", "tương", "đương", "học", "phí", "học", "năm", "học", "thứ", "tại", "trường", "đại", "học", "khoa", "học", "đại", "học", "huế"]}
{"id": "thi_sinh_khoahoc_qd_310_hoc_bong_khong_tinh_uu_tien_2024", "doc_id": "chunked_9", "chunk_id": 8, "text": "### thi sinh khoahoc qd 310 hoc bong khong tinh uu tien 2024\n\nCác mức học bổng trong Quyết định 310/QĐ-ĐHH của Trường Đại học Khoa học – Đại học Huế được xét theo điểm thi tốt nghiệp THPT năm 2024 **không tính điểm ưu tiên và điểm cộng**.", "text_plain": "Hoc bong xet theo diem thi THPT 2024 khong tinh diem uu tien/diem cong.", "summary": "Khi xét học bổng theo QĐ 310, dùng điểm thi THPT 2024 **không tính ưu tiên/điểm cộng**.", "metadata": {"source": "Quyết định 310/QĐ-ĐHH ngày 29/03/2024 (Đại học Huế)", "effective_date": "2024-03-29", "info_type": "uu_tien_xet_tuyen", "info_subtype": "hoc_bong", "audience": "thi_sinh", "issuer": "Dai_Hoc_Hue", "unit": "Khoa_Hoc", "year": "2024", "admission_cycle": 2025, "expired": false, "citations": ["Học bổng không tính ưu tiên/điểm cộng (QĐ 310/QĐ-ĐHH)"], "docno": "310/QĐ-ĐHH", "score_scale": "THPT/30", "source_type": "jsonl", "faq_type": "tieu_chi_phu"}, "breadcrumbs": ["Quyết định 310/QĐ-ĐHH ngày 29/03/2024 (Đại học Huế)"], "prev_chunk_id": "thi_sinh_khoahoc_qd_310_hoc_bong_26_28_2024", "next_chunk_id": "", "sparse_terms": ["mức", "học", "bổng", "quyết", "định", "310", "đhh", "trường", "đại", "học", "khoa", "học", "đại", "học", "huế", "xét", "điểm", "thi", "tốt", "nghiệp", "thpt", "năm", "2024", "tính", "điểm", "tiên", "điểm", "cộng"]}
