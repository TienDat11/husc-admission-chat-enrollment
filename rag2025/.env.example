# ============================================================
# .env.example – Copy to .env and fill in your values
# ============================================================

# ─── PRIMARY LLM (ramclouds.me – gemini-2.5-flash) ──────────
# Get your key from https://ramclouds.me
RAMCLOUDS_API_KEY=sk-your-key-here
RAMCLOUDS_BASE_URL=https://ramclouds.me/v1
RAMCLOUDS_MODEL=gemini-2.5-flash

# Note: OPENAI_API_KEY is also checked as fallback for RAMCLOUDS_API_KEY
# If you set OPENAI_API_KEY, it will be used for ramclouds.me automatically
# OPENAI_API_KEY=sk-your-key-here

# ─── FALLBACK LLM (Groq – free, fast) ───────────────────────
# Get your key from https://console.groq.com
GROQ_API_KEY=gsk_your-groq-key-here

# ─── NER FALLBACK (Qwen-3.5-Plus via Aliyun) ────────────────
# Optional – only needed if both ramclouds + groq fail for NER
# QWEN_API_KEY=sk-your-qwen-key-here

# ─── VECTOR DATABASE (LanceDB embedded) ──────────────────────
LANCEDB_URI=./data/lancedb
LANCEDB_TABLE=rag2025
LANCEDB_ENTITY_TABLE=husc_entities
USE_LANCEDB=true

# ─── EMBEDDING MODEL ─────────────────────────────────────────
# 4B = 8GB disk, 2560 dims — recommended for machines with ≥12GB free RAM/disk
# 0.6B = 1.2GB disk, 1024 dims — use on machines with limited disk/RAM
QWEN_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
QWEN_EMBEDDING_DIM=2560
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIM=2560

# ─── HUGGINGFACE CACHE (redirect to D: drive to avoid filling C:) ──────────
# Models download here. Default is C:\Users\<user>\.cache\huggingface (~20GB for 8B!)
# Change to D: drive path that has enough free space:
HF_HOME=D:/chunking/.cache/huggingface
TRANSFORMERS_CACHE=D:/chunking/.cache/huggingface/hub
RERANKER_MODEL=Qwen/Qwen3-Reranker-8B
RERANKER_ENABLED=true
RERANKER_WEIGHT=0.35
GUARDRAIL_ENABLED=true
GUARDRAIL_MODEL=llama-3.1-8b-instant
ERROR_EXPOSURE_MODE=dev

# ─── GRAPHRAG TUNING ─────────────────────────────────────────
# GRAPHRAG_ALPHA=0.6       # weight for vector score (1-alpha = PPR weight)
# GRAPHRAG_PPR_ALPHA=0.85  # PageRank damping factor
# GRAPHRAG_SIMPLE_THRESHOLD=2  # complexity <= this → PaddedRAG, else GraphRAG

# ─── API SERVER ───────────────────────────────────────────────
LOG_LEVEL=INFO
