# ============================================================
# .env.example вҖ“ Copy to .env and fill in your values
# ============================================================

# в”Җв”Җв”Җ PRIMARY LLM (ramclouds.me вҖ“ gemini-2.5-flash) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Get your key from https://ramclouds.me
RAMCLOUDS_API_KEY=sk-your-key-here
RAMCLOUDS_BASE_URL=https://ramclouds.me/v1
RAMCLOUDS_MODEL=gemini-2.5-flash

# Note: OPENAI_API_KEY is also checked as fallback for RAMCLOUDS_API_KEY
# If you set OPENAI_API_KEY, it will be used for ramclouds.me automatically
# OPENAI_API_KEY=sk-your-key-here

# в”Җв”Җв”Җ FALLBACK LLM (Groq вҖ“ free, fast) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Get your key from https://console.groq.com
GROQ_API_KEY=gsk_your-groq-key-here

# в”Җв”Җв”Җ NER FALLBACK (Qwen-3.5-Plus via Aliyun) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Optional вҖ“ only needed if both ramclouds + groq fail for NER
# QWEN_API_KEY=sk-your-qwen-key-here

# в”Җв”Җв”Җ VECTOR DATABASE (LanceDB embedded) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
LANCEDB_URI=./data/lancedb
LANCEDB_TABLE=rag2025
LANCEDB_ENTITY_TABLE=husc_entities
USE_LANCEDB=true

# в”Җв”Җв”Җ EMBEDDING MODEL в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# EMBEDDING_PROVIDER controls which prompt strategy to use.
# Set EMBEDDING_MODEL + EMBEDDING_DIM to match your chosen provider.
#
# в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
# в”Ӯ Provider  в”Ӯ Model                            в”Ӯ Dim  в”Ӯ Disk   в”Ӯ
# в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
# в”Ӯ qwen      в”Ӯ Qwen/Qwen3-Embedding-0.6B       в”Ӯ 1024 в”Ӯ 1.2GB  в”Ӯ
# в”Ӯ qwen      в”Ӯ Qwen/Qwen3-Embedding-4B         в”Ӯ 2560 в”Ӯ 8GB    в”Ӯ
# в”Ӯ qwen      в”Ӯ Qwen/Qwen3-Embedding-8B         в”Ӯ 4096 в”Ӯ 15GB   в”Ӯ
# в”Ӯ harrier   в”Ӯ microsoft/harrier-oss-v1-270m    в”Ӯ  640 в”Ӯ 0.5GB  в”Ӯ
# в”Ӯ harrier   в”Ӯ microsoft/harrier-oss-v1-0.6b    в”Ӯ 1024 в”Ӯ 1.2GB  в”Ӯ
# в”Ӯ harrier   в”Ӯ microsoft/harrier-oss-v1-27b     в”Ӯ 5376 в”Ӯ 54GB   в”Ӯ
# в”Ӯ bge       в”Ӯ BAAI/bge-m3                      в”Ӯ 1024 в”Ӯ 2.2GB  в”Ӯ
# в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
#
# Default: Qwen3-Embedding-4B (production balance)
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIM=2560

# Presets (used by benchmark scripts; not needed at runtime)
QWEN_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
QWEN_EMBEDDING_DIM=2560
HARRIER_EMBEDDING_MODEL=microsoft/harrier-oss-v1-0.6b
HARRIER_EMBEDDING_DIM=1024
BGE_EMBEDDING_MODEL=BAAI/bge-m3
BGE_EMBEDDING_DIM=1024

# в”Җв”Җв”Җ HUGGINGFACE CACHE (redirect to D: drive to avoid filling C:) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Models download here. Default is C:\Users\<user>\.cache\huggingface (~20GB for 8B!)
# Change to D: drive path that has enough free space:
HF_HOME=D:/chunking/.cache/huggingface
TRANSFORMERS_CACHE=D:/chunking/.cache/huggingface/hub
RERANKER_MODEL=Qwen/Qwen3-Reranker-8B
RERANKER_ENABLED=true
RERANKER_WEIGHT=0.35
GUARDRAIL_ENABLED=true
GUARDRAIL_MODEL=llama-3.1-8b-instant
ERROR_EXPOSURE_MODE=dev

# в”Җв”Җв”Җ GRAPHRAG TUNING в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# GRAPHRAG_ALPHA=0.6       # weight for vector score (1-alpha = PPR weight)
# GRAPHRAG_PPR_ALPHA=0.85  # PageRank damping factor
# GRAPHRAG_SIMPLE_THRESHOLD=2  # complexity <= this вҶ’ PaddedRAG, else GraphRAG

# в”Җв”Җв”Җ API SERVER в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
LOG_LEVEL=INFO
